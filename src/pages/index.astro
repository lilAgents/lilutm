            <path fill="currentColor" d="M894,156.7c8.1,4.2,14.5,9.7,19.1,16.4v-20.4h36.4v144.1c0,13.3-2.7,25.1-8,35.5-5.3,10.4-13.3,18.7-24,24.8-10.7,6.1-23.6,9.2-38.7,9.2s-37-4.7-50-14.2c-13-9.5-20.4-22.4-22.1-38.7h35.9c1.9,6.5,6,11.7,12.3,15.6,6.3,3.9,13.9,5.8,22.9,5.8s19-3.1,25.6-9.4c6.5-6.3,9.8-15.8,9.8-28.5v-22.2c-4.6,6.7-11.1,12.3-19.2,16.8-8.2,4.5-17.5,6.7-28,6.7s-23.1-3.1-33.1-9.3c-10-6.2-17.9-14.9-23.6-26.2-5.8-11.3-8.7-24.2-8.7-38.9s2.9-27.3,8.7-38.5c5.8-11.2,13.6-19.8,23.5-25.8,9.9-6,21-9,33.2-9s20.1,2.1,28.1,6.3ZM907.9,201.7c-3.4-6.3-8.1-11.1-13.9-14.5-5.9-3.4-12.1-5-18.8-5s-12.9,1.6-18.6,4.9c-5.7,3.3-10.3,8-13.8,14.3-3.5,6.3-5.3,13.7-5.3,22.3s1.8,16.1,5.3,22.6c3.5,6.5,8.2,11.4,13.9,14.8,5.8,3.4,11.9,5.2,18.5,5.2s13-1.7,18.8-5c5.9-3.4,10.5-8.2,13.9-14.5,3.4-6.3,5.2-13.8,5.2-22.6s-1.7-16.3-5.2-22.6Z"/>
            <path fill="currentColor" d="M1122,235.1h-104.6c.9,10.3,4.5,18.4,10.8,24.3,6.4,5.9,14.2,8.8,23.5,8.8,13.4,0,23-5.8,28.7-17.3h39c-4.1,13.8-12.1,25.1-23.8,34-11.7,8.9-26.1,13.3-43.1,13.3s-26.1-3.1-37.1-9.2c-10.9-6.1-19.5-14.8-25.6-26-6.1-11.2-9.2-24.1-9.2-38.7s3-27.8,9-39c6-11.2,14.5-19.8,25.3-25.8,10.8-6,23.3-9,37.4-9s25.8,2.9,36.5,8.8c10.8,5.9,19.1,14.2,25,24.9,5.9,10.8,8.9,23.1,8.9,37.1s-.3,9.8-1,13.9ZM1085.6,210.8c-.2-9.3-3.5-16.7-10.1-22.3-6.5-5.6-14.6-8.4-24-8.4s-16.5,2.7-22.6,8.1c-6.1,5.4-9.9,13-11.2,22.6h67.9Z"/>
            <path fill="currentColor" d="M1275.1,166.8c10.5,10.8,15.8,25.8,15.8,45.1v83.9h-36.1v-79c0-11.4-2.8-20.1-8.5-26.2-5.7-6.1-13.4-9.2-23.2-9.2s-17.9,3.1-23.6,9.2c-5.8,6.1-8.7,14.8-8.7,26.2v79h-36.1v-143.1h36.1v17.8c4.8-6.2,11-11.1,18.5-14.6,7.5-3.5,15.7-5.3,24.7-5.3,17,0,30.8,5.4,41.3,16.1Z"/>
            <path fill="currentColor" d="M1372.5,182.4v69.2c0,4.8,1.2,8.3,3.5,10.5,2.3,2.2,6.2,3.2,11.8,3.2h16.8v30.5h-22.7c-30.5,0-45.7-14.8-45.7-44.4v-68.9h-17v-29.7h17v-35.4h36.4v35.4h32v29.7h-32Z"/>
            <path fill="currentColor" d="M1459,291.8c-9.3-4.2-16.7-9.9-22.1-17.2-5.4-7.2-8.4-15.2-8.9-24h36.4c.7,5.5,3.4,10.1,8.1,13.7,4.7,3.6,10.6,5.4,17.7,5.4s12.3-1.4,16.1-4.1c3.9-2.8,5.8-6.3,5.8-10.6s-2.4-8.1-7.1-10.5c-4.7-2.3-12.3-4.9-22.6-7.6-10.7-2.6-19.4-5.3-26.2-8-6.8-2.8-12.7-7-17.6-12.7-4.9-5.7-7.4-13.3-7.4-23s2.3-15.1,6.8-21.7c4.6-6.5,11.1-11.7,19.6-15.5,8.5-3.8,18.5-5.7,30.1-5.7,17,0,30.6,4.3,40.8,12.8s15.8,20,16.8,34.5h-34.6c-.5-5.7-2.9-10.2-7.1-13.6-4.2-3.4-9.9-5-16.9-5s-11.6,1.2-15.1,3.6c-3.5,2.4-5.3,5.8-5.3,10.1s2.4,8.5,7.2,11c4.8,2.5,12.3,5,22.5,7.6,10.3,2.6,18.8,5.3,25.6,8,6.7,2.8,12.5,7,17.4,12.8,4.9,5.8,7.4,13.4,7.6,22.9,0,8.3-2.3,15.7-6.8,22.2-4.6,6.5-11.1,11.7-19.6,15.4-8.5,3.7-18.5,5.5-29.8,5.5s-22.2-2.1-31.5-6.3Z"/>
            <polygon fill="#536ee5" points="187.2 112.4 149.8 132.6 149.8 0 187.3 18.7 187.2 112.4"/>
            <polygon fill="#536ee5" points="74.8 58.4 74.8 95.8 112.2 77.1 112.2 39.6 74.8 58.4"/>
            <polygon fill="#536ee5" points="74.8 208 112.2 189.3 112.2 114.5 74.8 133.2 74.8 208"/>
            <polygon fill="#536ee5" points="37.4 264.1 37.4 236.1 37.4 77.1 0 95.8 0 254.8 0 320.2 37.4 301.5 74.8 282.8 112.2 264.1 112.2 226.7 37.4 264.1"/>
            <polygon fill="currentColor" points="149.9 282.5 149.9 357.3 187.3 376 187.3 301.2 149.9 282.5"/>
            <polygon fill="currentColor" points="187.3 226.2 149.9 207.5 149.9 244.9 187.3 263.6 187.3 226.2"/>
            <polygon fill="currentColor" points="224.8 170 187.1 151.3 149.9 170 224.8 207.1 224.8 394.8 262.2 413.5 262.2 225.8 262.2 188.7 224.8 170"/>
          </svg>
        </a>
        <span class="app-header__divider"></span>
        <div>
          <p class="app-header__name">lilUTM</p>
          <p class="app-header__tag">Campaign URL Builder</p>
        </div>
      </div>
      <button id="ui-theme-btn" class="ui-theme-btn" type="button" aria-label="Toggle dark mode"><svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path fill="currentColor" d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg></button>
    </header>

    <main class="app">
      <section class="pane form-pane">
        <div class="bar">
          <span class="bar__label">Quick fill</span>
          <div class="chips" id="presets">
            <button class="chip" type="button" data-src="newsletter" data-med="email">Email</button>
            <button class="chip" type="button" data-src="facebook" data-med="social">Facebook</button>
            <button class="chip" type="button" data-src="instagram" data-med="social">Instagram</button>
            <button class="chip" type="button" data-src="linkedin" data-med="social">LinkedIn</button>
            <button class="chip" type="button" data-src="x" data-med="social">X</button>
            <button class="chip" type="button" data-src="google" data-med="cpc">Google Ads</button>
          </div>
        </div>
        <div class="fields">
          <label class="field"><span class="field__label">Website URL <em>required</em></span>
            <input id="f-url" type="text" placeholder="https://acme.coffee/sale" autocomplete="off" spellcheck="false"/></label>
          <label class="field"><span class="field__label">Campaign source <em>utm_source</em></span>
            <input id="f-source" type="text" placeholder="newsletter, facebook, google" autocomplete="off"/></label>
          <label class="field"><span class="field__label">Campaign medium <em>utm_medium</em></span>
            <input id="f-medium" type="text" placeholder="email, social, cpc" autocomplete="off"/></label>
          <label class="field"><span class="field__label">Campaign name <em>utm_campaign</em></span>
            <input id="f-campaign" type="text" placeholder="summer_sale" autocomplete="off"/></label>
          <label class="field"><span class="field__label">Campaign term <em>utm_term &middot; optional</em></span>
            <input id="f-term" type="text" placeholder="running+shoes" autocomplete="off"/></label>
          <label class="field"><span class="field__label">Campaign content <em>utm_content &middot; optional</em></span>
            <input id="f-content" type="text" placeholder="logolink, textlink" autocomplete="off"/></label>
        </div>
      </section>

      <section class="pane out-pane">
        <div class="url-wrap">
          <div class="bar out-bar">
            <span class="badge badge--muted" id="status">Enter a website URL</span>
            <button id="copy-btn" class="btn btn--primary" type="button" disabled>Copy URL</button>
          </div>
          <div class="url-box"><a id="out-url" target="_blank"></a></div>
          <div class="param-list" id="params"></div>
          <a class="cta" href="https://lilqr.lilagents.com/" target="_blank">
            <span class="cta__icon">
              <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path fill="currentColor" d="M3 3h8v8H3V3Zm2 2v4h4V5H5Zm-2 8h8v8H3v-8Zm2 2v4h4v-4H5ZM13 3h8v8h-8V3Zm2 2v4h4V5h-4Zm-2 8h2v2h-2v-2Zm0 4h2v2h-2v-2Zm4-4h2v2h-2v-2Zm0 4h2v2h-2v-2Zm-2 2v2h2v-2h-2Zm4-6h2v2h-2v-2Zm0 4h2v4h-2v-4Z"/></svg>
            </span>
            <span class="cta__text">
              <strong>Need a QR code for this link?</strong>
              <span>Generate one in seconds with lilQR &rarr;</span>
            </span>
          </a>
        </div>
      </section>
    </main>

    <ToolFooter repoUrl="https://github.com/lilAgents/lilutm" />

    <script>
      import { initUtm } from '../scripts/utm.js';
      initUtm();
    </script>
  </body>
</html>
